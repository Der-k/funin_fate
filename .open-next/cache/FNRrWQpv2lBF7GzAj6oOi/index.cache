2F%2Fimages.unsplash.com%2Fphoto-1477959858617-67f85cf4f1df%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477959858617-67f85cf4f1df%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><div class=\"absolute inset-0\" style=\"background:linear-gradient(to bottom, #1B2A35 0%, transparent 30%, transparent 70%, #1B2A35 100%)\"></div><div class=\"absolute inset-0\" style=\"background:linear-gradient(135deg, #20B2AA18 0%, transparent 50%)\"></div><div class=\"absolute top-0 left-0 right-0 h-px\" style=\"background:linear-gradient(to right, transparent, #20B2AA40, transparent)\"></div><div class=\"relative max-w-[1300px] mx-auto px-6 md:px-12 lg:px-16 flex flex-col gap-10\" style=\"padding-top:6rem;padding-bottom:6rem\"><div class=\"flex flex-col lg:flex-row items-start lg:items-end justify-between gap-10\"><div class=\"max-w-xl\"><div class=\"flex items-center gap-3 mb-6\"><div class=\"w-6 h-px\" style=\"background:#20B2AA\"></div><span class=\"text-sm uppercase tracking-[0.35em]\" style=\"color:#20B2AAAA;font-weight:700\">Plan Your Visit</span></div><h2 class=\"leading-[0.92]\" style=\"font-size:clamp(2.6rem, 6vw, 4.8rem);color:#F5DEB3;font-weight:700\">Come experience <br/><span style=\"color:#CC4125\">Fate for yourself.</span></h2><p class=\"leading-relaxed mt-6\" style=\"font-size:1rem;color:rgba(245,222,179,0.5);max-width:36ch;font-weight:400\">Register now to get early access to events, curated itineraries, and exclusive experiences available only in Fate.</p></div><div class=\"w-full lg:w-auto lg:min-w-[340px] flex-shrink-0 relative p-8 rounded-[28px]\" style=\"border:1px solid #20B2AA45;background:rgba(27,42,53,0.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)\"><p class=\"text-xs uppercase tracking-[0.25em] mb-2\" style=\"color:#20B2AA90;font-weight:700\">Free Registration</p><h3 class=\"leading-tight mb-1\" style=\"font-size:1.6rem;color:#F5DEB3;font-weight:700\">Join Fate</h3><p class=\"text-sm mb-7\" style=\"color:rgba(245,222,179,0.45);font-weight:400\">Get early access. No spam, ever.</p><div class=\"relative mb-4\"><input type=\"email\" placeholder=\"Your email address\" class=\"w-full bg-transparent text-sm outline-none rounded-full\" style=\"border:1px solid rgba(32,178,170,0.3);padding:14px 18px;color:#F5DEB3;font-size:0.94rem\"/></div><a class=\"group w-full flex items-center justify-between px-5 py-4 text-sm rounded-full\" style=\"background:#20B2AA;color:#0D1B24;letter-spacing:0.04em;font-weight:700;transition:background 300ms ease\" href=\"/register\"><span>Register for Free</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform\" aria-hidden=\"true\" style=\"width:16px;height:16px\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></a><p class=\"text-xs mt-4 text-center\" style=\"color:rgba(245,222,179,0.25);font-weight:400\">By registering you agree to our Terms &amp; Privacy Policy</p></div></div></div></div><div class=\"h-px\" style=\"background:linear-gradient(90deg, transparent, #20B2AA40, #CC412540, transparent)\"></div></section><section class=\"relative overflow-hidden px-4 sm:px-6 py-14 sm:py-20 md:px-10 lg:px-16 bg-white\"><div class=\"relative z-10 mx-auto max-w-7xl\"><div class=\"mb-10 sm:mb-16 max-w-3xl\"><div class=\"flex items-center gap-3\"><span class=\"h-2 w-2 rounded-full bg-[#CC4125]\"></span><p class=\"text-sm sm:text-base uppercase tracking-[0.25em] sm:tracking-[0.35em] text-[#20B2AA] __className_ebdfad\">Restaurants &amp; Nightlife</p></div><h2 class=\"mt-4 text-4xl sm:text-5xl font-black uppercase leading-[0.95] text-[#36454F] md:text-7xl __className_ebdfad\">Eat and<br/>Drink.</h2><div class=\"mt-4 h-[3px] w-20 sm:w-24 rounded-full bg-gradient-to-r from-[#CC4125] via-[#20B2AA] to-transparent\"></div><p class=\"mt-5 sm:mt-6 text-xl sm:text-2xl leading-relaxed text-[#36454F]/60 __className_ebdfad\">Discover premium dining destinations, social venues, networking lounges, and curated culinary experiences designed around the energy of Funinfate.</p></div><div class=\"mb-5 lg:hidden\"><div class=\"relative overflow-hidden rounded-[24px] sm:rounded-[32px] border border-[#F5DEB3]/15 bg-[#36454F]/80 p-6 sm:p-8 shadow-2xl backdrop-blur-sm h-full\"><div class=\"absolute -right-20 -top-20 h-56 w-56 rounded-full bg-[#20B2AA]/25 blur-3xl\"></div><div class=\"absolute -left-16 -bottom-16 h-48 w-48 rounded-full bg-[#CC4125]/20 blur-3xl\"></div><div class=\"relative z-10\"><p class=\"text-sm uppercase tracking-[0.35em] text-[#20B2AA] __className_ebdfad\">Culinary Experiences</p><h2 class=\"mt-4 text-3xl sm:text-4xl lg:text-5xl font-black uppercase leading-none text-[#F5DEB3] __className_ebdfad\">Taste The<br/>Future Of<br/>Funinfate</h2><p class=\"mt-4 sm:mt-5 max-w-md text-xl sm:text-2xl leading-relaxed text-[#F5DEB3]/70 __className_ebdfad\">From immersive rooftop lounges to curated chef experiences, discover the restaurants, nightlife, and social spaces powering the energy of Funinfate.</p><div class=\"mt-5 sm:mt-6 h-px w-16 bg-gradient-to-r from-[#CC4125] to-transparent\"></div><div class=\"mt-5 sm:mt-6 flex flex-col xs:flex-row flex-wrap gap-3 sm:gap-4\"><a class=\"group inline-flex items-center justify-center gap-2 rounded-full bg-[#20B2AA] px-5 sm:px-6 py-2.5 sm:py-3 text-base font-semibold text-[#020817] transition hover:scale-[1.02] hover:bg-[#1a9e97] __className_ebdfad\" href=\"/restaurants\">Explore Dining<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w